{
  "name": "@ifthakhar8/pdf-cutter",
  "version": "0.1.5",
  "description": "React PDF workspace: pick pages, reorder, persist selection, export a merged PDF (Ant Design + react-pdf + pdf-lib).",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/ifthakhar94/pdf-cutter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ifthakhar94/pdf-cutter.git"
  },
  "bugs": {
    "url": "https://github.com/ifthakhar94/pdf-cutter/issues"
  },
  "keywords": [
    "react",
    "pdf",
    "pdf-lib",
    "react-pdf",
    "merge-pdf",
    "antd"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "docs/playground-screenshot.png"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/pdf-cutter.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts",
    "build:playground": "vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@ant-design/icons": "^5.0.0 || ^6.0.0",
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "@dnd-kit/utilities": "^3.0.0",
    "antd": "^5.0.0 || ^6.0.0",
    "pdf-lib": "^1.17.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-pdf": "^9.0.0 || ^10.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@ant-design/icons": "^6.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "antd": "^6.3.7",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-pdf": "^10.4.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  }
}
